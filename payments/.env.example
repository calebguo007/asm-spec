# ═══════════════════════════════════════════════════════════
# ASM × Circle Nanopayments Environment Variables
# ═══════════════════════════════════════════════════════════

# ── Circle Gateway ──────────────────────────────────────
# Circle API Key (from console.circle.com)
CIRCLE_API_KEY=TEST_API_KEY:xxxxxxxx:xxxxxxxx

# ── Wallet Configuration ────────────────────────────────────────────
# Seller wallet address (receives USDC)
SELLER_ADDRESS=0xYourSellerWalletAddress

# Buyer wallet private key (Agent payment, testnet only!)
BUYER_PRIVATE_KEY=0xYourBuyerPrivateKey

# ── Network Configuration ────────────────────────────────────────────
# Target chain: arcTestnet
CHAIN=arcTestnet
# CAIP-2 Network identifier
NETWORK=eip155:1301

# ── ASM Registry ────────────────────────────────────────
# ASM HTTP API URL
ASM_REGISTRY_URL=http://localhost:3456

# ── Pricing ────────────────────────────────────────────────
# Price per /api/score call (USDC)
SCORE_PRICE=$0.005
# Price per /api/query call (USDC)
QUERY_PRICE=$0.002

# ── ServicePort ────────────────────────────────────────────
PAYMENT_SERVER_PORT=4402
